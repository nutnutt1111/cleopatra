// DonutiT — primary app schema (see docs/PRIMARY-APP.md)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  OWNER
  MANAGER
  STAFF
  HR
}

enum LedgerEntryType {
  INCOME
  EXPENSE
  TRANSFER_IN
  TRANSFER_OUT
}

enum PaymentChannel {
  CASH
  TRANSFER
  CREDIT
  OTHER
}

enum AuditAction {
  LEDGER_POST
  LEDGER_VOID
  DAILY_CLOSE
  DAILY_CLOSE_UNLOCK
  POS_SALE
  POS_VOID
  STOCK_MOVE
  PAWN_CREATE
  PAWN_INTEREST
  PAWN_REDEEM
  PAWN_VOID
  CREDIT_SALE
  CUSTOMER_PAYMENT
  MESSENGER_CREATE
  MESSENGER_DELIVER
  MESSENGER_CANCEL
  HR_EMPLOYEE_CREATE
  PAYROLL_RUN
  PAYROLL_PAY
}

enum TrackingType {
  SERIALIZED
  QUANTITY
}

enum ItemStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum PosBillStatus {
  COMPLETED
  VOIDED
}

enum StockMoveReason {
  SALE
  VOID_RESTORE
  ADJUSTMENT
  RECEIVE
}

enum PawnTicketStatus {
  ACTIVE
  REDEEMED
  VOIDED
}

enum PawnPaymentType {
  INTEREST
  REDEEM
}

enum CreditSaleStatus {
  OPEN
  PAID
  VOIDED
}

enum InstallmentStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

enum DeliveryJobStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PAID
}

model Store {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  users         User[]
  ledgerEntries LedgerEntry[]
  dailyCloses   DailyClose[]
  auditLogs     AuditLog[]
  products      Product[]
  productCategories ProductCategory[]
  serialItems   SerialItem[]
  stockMoves    StockMovement[]
  posBills      PosBill[]
  customers     Customer[]
  pawnTickets   PawnTicket[]
  creditSales   CreditSale[]
  deliveryJobs  DeliveryJob[]
  employees     Employee[]
  payrollRuns   PayrollRun[]

  @@index([code])
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String
  passwordHash     String
  role             Role            @default(STAFF)
  canExportReports Boolean         @default(false)
  storeId          String
  store            Store           @relation(fields: [storeId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ledgerEntries    LedgerEntry[]   @relation("LedgerCreatedBy")
  dailyCloses      DailyClose[]    @relation("DailyCloseBy")
  unlockedCloses   DailyClose[]    @relation("DailyCloseUnlockedBy")
  auditLogs        AuditLog[]
  posBills         PosBill[]       @relation("PosBillCreatedBy")
  voidedBills      PosBill[]       @relation("PosBillVoidedBy")
  stockMoves       StockMovement[]
  pawnTickets      PawnTicket[]       @relation("PawnCreatedBy")
  redeemedTickets  PawnTicket[]       @relation("PawnRedeemedBy")
  voidedTickets    PawnTicket[]       @relation("PawnVoidedBy")
  pawnPayments     PawnPayment[]
  creditSales      CreditSale[]       @relation("CreditSaleCreatedBy")
  customerPayments CustomerPayment[]
  deliveryJobs     DeliveryJob[]     @relation("DeliveryCreatedBy")
  deliveredJobs    DeliveryJob[]     @relation("DeliveryDeliveredBy")
  employeesCreated Employee[]        @relation("EmployeeCreatedBy")
  payrollRuns      PayrollRun[]      @relation("PayrollCreatedBy")
  payrollPaid      PayrollRun[]      @relation("PayrollPaidBy")

  @@index([storeId])
  @@index([role])
}

model ProductCategory {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  name      String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@unique([storeId, name])
  @@index([storeId, sortOrder])
}

model Product {
  id           String           @id @default(cuid())
  storeId      String
  store        Store            @relation(fields: [storeId], references: [id])
  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  sku          String
  name         String
  trackingType TrackingType @default(QUANTITY)
  priceCents   Int
  costCents    Int          @default(0)
  qtyOnHand    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  serialItems  SerialItem[]
  billLines    PosBillLine[]
  stockMoves   StockMovement[]

  @@unique([storeId, sku])
  @@index([storeId, trackingType])
  @@index([storeId, categoryId])
}

model SerialItem {
  id           String     @id @default(cuid())
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  serialNumber String
  status       ItemStatus @default(AVAILABLE)
  costCents    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  billLines    PosBillLine[]
  stockMoves   StockMovement[]

  @@unique([storeId, serialNumber])
  @@index([productId, status])
}

model StockMovement {
  id            String          @id @default(cuid())
  storeId       String
  store         Store           @relation(fields: [storeId], references: [id])
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  serialItemId  String?
  serialItem    SerialItem?     @relation(fields: [serialItemId], references: [id])
  qtyDelta      Int
  reason        StockMoveReason
  referenceType String?
  referenceId   String?
  note          String?
  createdById   String
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())

  @@index([storeId, createdAt])
  @@index([referenceType, referenceId])
}

model PosBill {
  id             String        @id @default(cuid())
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id])
  billNumber     String
  status         PosBillStatus @default(COMPLETED)
  subtotalCents  Int
  discountCents  Int           @default(0)
  totalCents     Int
  voidedAt       DateTime?
  voidReason     String?
  createdById    String
  createdBy      User          @relation("PosBillCreatedBy", fields: [createdById], references: [id])
  voidedById     String?
  voidedBy       User?         @relation("PosBillVoidedBy", fields: [voidedById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lines          PosBillLine[]
  payments       PosPayment[]

  @@unique([storeId, billNumber])
  @@index([storeId, status])
  @@index([createdAt])
}

model PosBillLine {
  id             String      @id @default(cuid())
  billId         String
  bill           PosBill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  serialItemId   String?
  serialItem     SerialItem? @relation(fields: [serialItemId], references: [id])
  qty            Int         @default(1)
  unitPriceCents Int
  lineTotalCents Int

  @@index([billId])
}

model PosPayment {
  id             String         @id @default(cuid())
  billId         String
  bill           PosBill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  channel        PaymentChannel
  amountCents    Int
  transferDetail String?

  @@index([billId])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  storeId       String
  store         Store           @relation(fields: [storeId], references: [id])
  entryDate     DateTime
  type          LedgerEntryType
  channel       PaymentChannel  @default(CASH)
  amountCents   Int
  description   String
  referenceType String?
  referenceId   String?
  isVoided      Boolean         @default(false)
  voidedAt      DateTime?
  voidReason    String?
  reversalOfId  String?         @unique
  reversalOf    LedgerEntry?    @relation("LedgerReversal", fields: [reversalOfId], references: [id])
  reversal      LedgerEntry?    @relation("LedgerReversal")
  createdById   String
  createdBy     User            @relation("LedgerCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([storeId, entryDate])
  @@index([referenceType, referenceId])
  @@index([isVoided])
}

model DailyClose {
  id                   String   @id @default(cuid())
  storeId              String
  store                Store    @relation(fields: [storeId], references: [id])
  closeDate            DateTime
  isLocked             Boolean  @default(true)
  cashIncomeCents      Int      @default(0)
  cashExpenseCents     Int      @default(0)
  transferIncomeCents  Int      @default(0)
  transferExpenseCents Int      @default(0)
  note                 String?
  closedById           String
  closedBy             User     @relation("DailyCloseBy", fields: [closedById], references: [id])
  unlockedAt           DateTime?
  unlockedById         String?
  unlockedBy           User?    @relation("DailyCloseUnlockedBy", fields: [unlockedById], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([storeId, closeDate])
  @@index([storeId, closeDate])
  @@index([isLocked])
}

model Customer {
  id               String            @id @default(cuid())
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id])
  name             String
  phone            String?
  creditLimitCents Int               @default(0)
  balanceCents     Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  pawnTickets      PawnTicket[]
  creditSales      CreditSale[]
  payments         CustomerPayment[]

  @@index([storeId, name])
  @@index([storeId, phone])
}

model PawnTicket {
  id                 String           @id @default(cuid())
  storeId            String
  store              Store            @relation(fields: [storeId], references: [id])
  ticketNumber       String
  customerId         String?
  customer           Customer?        @relation(fields: [customerId], references: [id])
  customerName       String
  customerPhone      String?
  itemDescription    String
  principalCents     Int
  interestRateBps    Int              @default(200)
  interestPeriodDays Int              @default(30)
  nextInterestDueAt  DateTime
  status             PawnTicketStatus @default(ACTIVE)
  transferDetail     String?
  createdById        String
  createdBy          User             @relation("PawnCreatedBy", fields: [createdById], references: [id])
  redeemedAt         DateTime?
  redeemedById       String?
  redeemedBy         User?            @relation("PawnRedeemedBy", fields: [redeemedById], references: [id])
  voidedAt           DateTime?
  voidReason         String?
  voidedById         String?
  voidedBy           User?            @relation("PawnVoidedBy", fields: [voidedById], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  payments           PawnPayment[]

  @@unique([storeId, ticketNumber])
  @@index([storeId, status])
  @@index([customerId])
}

model PawnPayment {
  id             String          @id @default(cuid())
  ticketId       String
  ticket         PawnTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type           PawnPaymentType
  amountCents    Int
  channel        PaymentChannel  @default(CASH)
  transferDetail String?
  /** Idempotency key for interest payments — one per due period */
  periodKey      String?         @unique
  createdById    String
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())

  @@index([ticketId])
}

model CreditSale {
  id             String             @id @default(cuid())
  storeId        String
  store          Store              @relation(fields: [storeId], references: [id])
  customerId     String
  customer       Customer           @relation(fields: [customerId], references: [id])
  saleNumber     String
  description    String
  totalCents     Int
  paidCents      Int                @default(0)
  status         CreditSaleStatus   @default(OPEN)
  createdById    String
  createdBy      User               @relation("CreditSaleCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  installment    InstallmentPlan?
  payments       CustomerPayment[]

  @@unique([storeId, saleNumber])
  @@index([storeId, status])
  @@index([customerId])
}

model InstallmentPlan {
  id                     String            @id @default(cuid())
  creditSaleId           String            @unique
  creditSale             CreditSale        @relation(fields: [creditSaleId], references: [id], onDelete: Cascade)
  installmentCount       Int
  installmentAmountCents Int
  installmentPeriodDays  Int               @default(30)
  paidInstallments       Int               @default(0)
  nextDueDate            DateTime
  status                 InstallmentStatus @default(ACTIVE)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([status, nextDueDate])
}

model CustomerPayment {
  id             String         @id @default(cuid())
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id])
  creditSaleId   String?
  creditSale     CreditSale?    @relation(fields: [creditSaleId], references: [id])
  amountCents    Int
  channel        PaymentChannel @default(CASH)
  transferDetail String?
  note           String?
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())

  @@index([customerId, createdAt])
  @@index([creditSaleId])
}

model DeliveryJob {
  id               String            @id @default(cuid())
  storeId          String
  store            Store             @relation(fields: [storeId], references: [id])
  jobNumber        String
  customerName     String
  customerPhone    String?
  address          String
  description      String?
  deliveryFeeCents Int               @default(0)
  feeChannel       PaymentChannel    @default(CASH)
  status           DeliveryJobStatus @default(PENDING)
  createdById      String
  createdBy        User              @relation("DeliveryCreatedBy", fields: [createdById], references: [id])
  deliveredAt      DateTime?
  deliveredById    String?
  deliveredBy      User?             @relation("DeliveryDeliveredBy", fields: [deliveredById], references: [id])
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([storeId, jobNumber])
  @@index([storeId, status])
  @@index([createdAt])
}

model Employee {
  id           String        @id @default(cuid())
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  employeeCode String
  name         String
  phone        String?
  position     String?
  salaryCents  Int           @default(0)
  hireDate     DateTime
  isActive     Boolean       @default(true)
  createdById  String
  createdBy    User          @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payrollLines PayrollLine[]

  @@unique([storeId, employeeCode])
  @@index([storeId, isActive])
}

model PayrollRun {
  id          String        @id @default(cuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  periodLabel String
  periodStart DateTime
  periodEnd   DateTime
  totalCents  Int
  status      PayrollStatus @default(DRAFT)
  createdById String
  createdBy   User          @relation("PayrollCreatedBy", fields: [createdById], references: [id])
  paidAt      DateTime?
  paidById    String?
  paidBy      User?         @relation("PayrollPaidBy", fields: [paidById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       PayrollLine[]

  @@index([storeId, status])
  @@index([periodStart, periodEnd])
}

model PayrollLine {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id])
  amountCents  Int
  note         String?

  @@index([payrollRunId])
  @@index([employeeId])
}

model AuditLog {
  id         String      @id @default(cuid())
  storeId    String
  store      Store       @relation(fields: [storeId], references: [id])
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  action     AuditAction
  entityType String
  entityId   String?
  payload    String?
  createdAt  DateTime    @default(now())

  @@index([storeId, createdAt])
  @@index([entityType, entityId])
}
