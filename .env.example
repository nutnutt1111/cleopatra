# Supabase (required for employee login)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: page after successful login (default: dashboard)
# Do NOT set this to the employee settings page unless you want every login to land there.
VITE_AUTH_REDIRECT=/pages/index.html
