# DonutiT (donutit-cleopatra) — Environment (copy to .env)
# User-facing app: http://localhost:3005 — API at /api/... on same origin

# SQLite dev (Wave 0). Production: switch to PostgreSQL URL.
DATABASE_URL="file:./prisma/dev.db"

# Internal API process port (Vite on :3005 proxies /api here in dev)
API_PORT=3004
JWT_SECRET="change-me-in-production"

# Vite frontend (donutit-cleopatra)
PORT=3005

# CORS (comma-separated origins allowed to call API with credentials)
CORS_ORIGINS=http://localhost:3005

# Return JWT in login JSON body (dev/quality only — default off in production)
LOGIN_RETURN_TOKEN=true

# Login rate limit (per IP). Raise for local quality gates.
LOGIN_RATE_MAX=200

# Quality scripts — same origin as the app
QUALITY_BASE_URL=http://localhost:3005
QUALITY_API_URL=http://localhost:3005
QUALITY_DEV_PASSWORD=donutit-dev

# CSRF double-submit cookie on mutating API routes (set false to disable in local scripts)
CSRF_ENFORCE=true
